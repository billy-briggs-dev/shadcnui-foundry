{
  "name": "@shadcnui-foundry/playground-react",
  "version": "0.0.0",
  "private": true,
  "description": "React component playground for generated components",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "node ./scripts/build.mjs",
    "storybook": "storybook dev -p 6006 -c ./.storybook-cjs",
    "storybook:build": "storybook build -c ./.storybook-cjs",
    "lint": "biome check ./scripts ./.storybook-cjs ./stories",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@shadcnui-foundry/react": "workspace:*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@shadcnui-foundry/typescript-config": "workspace:*",
    "rimraf": "^6.0.1",
    "storybook": "^8.6.14",
    "typescript": "^5.7.3",
    "vite": "^6.3.5"
  }
}
