{
  "name": "@shadcnui-foundry/angular",
  "version": "0.0.0",
  "description": "Angular component generation target for shadcnui-foundry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "storybook": "ng run shadcnui-foundry-angular:storybook",
    "storybook:build": "ng run shadcnui-foundry-angular:build-storybook",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src ./.storybook",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/common": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/platform-browser": "^21.2.1",
    "@angular/platform-browser-dynamic": "^21.2.1",
    "@shadcnui-foundry/core": "workspace:*",
    "@shadcnui-foundry/ir": "workspace:*",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@angular-devkit/build-angular": "^21.2.1",
    "@shadcnui-foundry/typescript-config": "workspace:*",
    "@shadcnui-foundry/vitest-config": "workspace:*",
    "@storybook/angular": "^10.2.16",
    "@storybook/builder-vite": "^10.2.16",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^4.0.8"
  }
}
