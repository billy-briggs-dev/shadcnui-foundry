{
  "name": "@shadcnui-foundry/playground-vue",
  "version": "0.0.0",
  "private": true,
  "description": "Vue component playground for generated components",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "node ./scripts/build.mjs",
