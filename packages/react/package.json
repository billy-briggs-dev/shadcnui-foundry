{
  "name": "@shadcnui-foundry/react",
  "version": "0.0.0",
  "description": "React component generation target for shadcnui-foundry",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "storybook": "storybook dev -p 6106 -c ./.storybook",
    "storybook:build": "storybook build -c ./.storybook",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src ./.storybook",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@shadcnui-foundry/core": "workspace:*",
    "@shadcnui-foundry/ir": "workspace:*",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@shadcnui-foundry/typescript-config": "workspace:*",
    "@shadcnui-foundry/vitest-config": "workspace:*",
    "@storybook/react": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "storybook": "^10.2.16",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^3.0.5"
  }
}
