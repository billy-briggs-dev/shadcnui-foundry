{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: foundry ingest button",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/packages/cli/dist/bin/foundry.js",
      "args": ["ingest", "button"],
      "cwd": "${workspaceFolder}",
      "env": { "LOG_LEVEL": "debug" },
      "runtimeArgs": ["--enable-source-maps"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug: current test file",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/node_modules/.bin/vitest",
      "args": ["run", "${file}"],
      "cwd": "${workspaceFolder}",
      "runtimeArgs": ["--enable-source-maps"]
    }
  ]
}
