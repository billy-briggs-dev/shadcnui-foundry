{
  "name": "@shadcnui-foundry/vue",
  "version": "0.0.0",
  "description": "Vue component generation target for shadcnui-foundry",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "storybook": "storybook dev -p 6107 -c ./.storybook-cjs",
    "storybook:build": "storybook build -c ./.storybook-cjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src ./stories ./.storybook-cjs",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@shadcnui-foundry/core": "workspace:*",
    "@shadcnui-foundry/ir": "workspace:*"
  },
  "devDependencies": {
    "@storybook/vue3": "^8.6.14",
    "@storybook/vue3-vite": "^8.6.14",
    "@shadcnui-foundry/typescript-config": "workspace:*",
    "@shadcnui-foundry/vitest-config": "workspace:*",
    "rimraf": "^6.0.1",
    "storybook": "^8.6.14",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vite": "^6.3.5",
    "vitest": "^3.0.5"
  }
}
