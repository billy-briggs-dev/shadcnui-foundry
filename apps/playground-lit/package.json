{
  "name": "@shadcnui-foundry/playground-lit",
  "version": "0.0.0",
  "private": true,
  "description": "Lit component playground for generated components",
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "build": "node ./scripts/build.mjs",
    "storybook": "storybook dev -p 6010 -c ./.storybook-cjs",
    "storybook:build": "storybook build -c ./.storybook-cjs",
    "lint": "biome check ./scripts ./.storybook-cjs ./stories",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@shadcnui-foundry/lit": "workspace:*",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@storybook/web-components": "^8.6.14",
    "@storybook/web-components-vite": "^8.6.14",
    "@shadcnui-foundry/typescript-config": "workspace:*",
    "rimraf": "^6.0.1",
    "storybook": "^8.6.14",
    "vite": "^6.3.5",
    "typescript": "^5.7.3"
  }
}
